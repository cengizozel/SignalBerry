<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top bar (unchanged) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:background="@color/colorBackground">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/title_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chat" android:textStyle="bold" android:textSize="18sp"/>
    </RelativeLayout>

    <!-- Selection bar (shown in multi-select mode) -->
    <LinearLayout
        android:id="@+id/selection_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1976D2"
        android:paddingStart="4dp" android:paddingEnd="4dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_cancel_selection"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"
            android:contentDescription="Cancel selection"/>

        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btn_delete_selected"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FFFFFF"
            android:contentDescription="Delete selected"/>
    </LinearLayout>

    <!-- Messages list (RecyclerView now) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Reply preview (shown when user long-presses a message) -->
    <LinearLayout
        android:id="@+id/reply_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="4dp"
        android:paddingTop="6dp" android:paddingBottom="6dp"
        android:background="@color/colorSurface"
        android:visibility="gone">

        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="#2196F3"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_reply_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"/>

        <ImageButton
            android:id="@+id/btn_cancel_reply"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:contentDescription="Cancel reply"/>
    </LinearLayout>

    <!-- Debug log (toggle in Settings) -->
    <LinearLayout
        android:id="@+id/debug_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111111"
        android:visibility="gone">
        <Button
            android:id="@+id/btn_copy_log"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_margin="2dp"
            android:text="Copy"
            android:textSize="10sp"
            android:padding="2dp"/>
        <ScrollView
            android:id="@+id/debug_scroll"
            android:layout_width="match_parent"
            android:layout_height="120dp">
            <TextView
                android:id="@+id/debug_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF00"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:padding="4dp"/>
        </ScrollView>
    </LinearLayout>

    <!-- Composer (unchanged) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:background="@color/colorBackground">

        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="Attach" />

        <EditText
            android:id="@+id/input_message"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Message" android:singleLine="true"
            android:textColor="#222222"
            android:textColorHint="@color/colorTextMuted"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"/>

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send" />
    </LinearLayout>
</LinearLayout>
