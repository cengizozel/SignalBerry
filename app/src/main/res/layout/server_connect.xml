<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect to signal-cli server"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <!-- IP or host:port -->
        <EditText
            android:id="@+id/input_ip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IP:port or https URL"
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:padding="8dp" />

        <!-- Your Signal number -->
        <EditText
            android:id="@+id/input_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your Signal number"
            android:inputType="phone"
            android:singleLine="true"
            android:padding="8dp"
            android:layout_marginTop="12dp" />

        <!-- Section 1: remote access (only to use the app away from home) -->
        <TextView
            android:id="@+id/remote_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Remote access"
            android:textColor="#888888"
            android:paddingTop="18dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/remote_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="For use away from home WiFi. A bridge token is strongly recommended: it stops anyone who finds your address from using your account. Once your server uses one, the app needs it here to connect."
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/input_bridge_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Bridge URL (https://…)"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:padding="8dp" />

            <EditText
                android:id="@+id/input_bridge_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Bridge token"
                android:inputType="textPassword"
                android:singleLine="true"
                android:padding="8dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Section 2: Cloudflare Access (a distinct, optional extra layer) -->
        <TextView
            android:id="@+id/cf_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Cloudflare Access (optional)"
            android:textColor="#888888"
            android:paddingTop="14dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/cf_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="An extra gate at Cloudflare's edge: it checks a service token and turns away anyone without it before the request ever reaches your server, a second layer on top of the bridge token. Leave blank unless you set up an Access service token in Cloudflare."
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/input_cf_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="CF Access Client ID"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:padding="8dp" />

            <EditText
                android:id="@+id/input_cf_secret"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="CF Access Client Secret"
                android:inputType="textPassword"
                android:singleLine="true"
                android:padding="8dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</ScrollView>
